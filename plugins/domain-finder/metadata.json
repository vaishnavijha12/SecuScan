{
  "id": "domain-finder",
  "name": "Domain Finder",
  "version": "1.0.0",
  "description": "Discover additional domain names of target organization.",
  "long_description": "Discover additional domain names of target organization.",
  "category": "recon",
  "author": {
    "name": "SecuScan Contributors",
    "email": "dev@secuscan.local"
  },
  "license": "MIT",
  "icon": "\ud83d\udd0e",
  "engine": {
    "type": "cli",
    "binary": "amass"
  },
  "command_template": [
    "amass",
    "enum",
    "-d",
    "{target}",
    "-dir",
    "/tmp/amass",
    "-silent"
  ],
  "fields": [
    {
      "id": "target",
      "label": "Root Domain",
      "type": "string",
      "required": true,
      "placeholder": "secuscan.in"
    }
  ],
  "presets": {
    "default": {}
  },
  "output": {
    "format": "text",
    "parser": "custom"
  },
  "safety": {
    "level": "safe",
    "requires_consent": false,
    "rate_limit": {
      "max_per_hour": 20,
      "max_concurrent": 1
    }
  },
  "dependencies": {
    "binaries": [
      "amass"
    ],
    "python_packages": [],
    "system_packages": []
  },
  "checksum": "b8bc0ebc7ba6b739c3f81be706c98cc354e9ffdad1468d62ef00600a3e8907d6"
}
